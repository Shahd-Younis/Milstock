{
  "name": "milstock-project",
  "private": true,
  "scripts": {
    "init:env": "node scripts/ensure-env.js",
    "install:all": "npm --prefix backend install && npm --prefix front-end install",
    "setup:demo": "npm run init:env && npm run install:all && npm run seed",
    "seed": "npm --prefix backend run seed",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix front-end run dev",
    "start:backend": "npm --prefix backend start",
    "build:frontend": "npm --prefix front-end run build"
  }
}
